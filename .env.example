# Copy to `.env` and fill in values. Do not commit `.env`.

# Interactive / channel bot (e.g. aiogram start_telegram_bot.py)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Project Nexus bot — Polymarket scheduled AI alerts (start_telegram_bot.py) + wallet safety brake (wallet_manager).
# Required if TELEGRAM_BOT_TOKEN is a channel-only bot; send /start to this bot once so it can message you.
TELEGRAM_NEXUS_BOT_TOKEN=
# Optional; defaults to TELEGRAM_ADMIN_CHAT_ID
# TELEGRAM_NEXUS_ADMIN_CHAT_ID=
# When dashboard portfolio_value is 0, AI alert Execute uses this USD floor (default 5)
# POLY_ALERT_MIN_ORDER_USD=5
# Live Polymarket BUY kill-switch floor in CLOB USDC (default 90). Set to 0 to disable the balance gate (dev only).
# POLY_KILL_SWITCH_MIN_USD=90
# CLOB signer kind: 0=EOA (MetaMask), 1=POLY_PROXY (email/Magic), 2=GNOSIS_SAFE. Wrong value often shows $0 balance.
# POLYMARKET_CLOB_SIGNATURE_TYPE=0
# Default 1: align POLYMARKET_SIGNER_ADDRESS + POLYMARKET_PORTFOLIO_ADDRESS with the wallet key. Set 0 only to pin a different UI portfolio address.
# POLYMARKET_SYNC_WALLET_ENV=1
# my.telegram.org — required for POST /api/sessions/* (Telethon user sessions)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Telethon swarm: cap parallel MTProto slots (default 30). Also: NEXUS_TELEGRAM_NETWORK_CONCURRENCY.
# TELEGRAM_NETWORK_CONCURRENCY=30
# Sticky residential proxy per session stem (hash of stem → pool index). Optional fail-closed:
# NEXUS_STRICT_SESSION_PROXY=1
# NEXUS_RESIDENTIAL_PROXY_POOL=socks5h://user:pass@host:port,socks5h://...
# NEXUS_SPAMBOT_WEEKLY_CRON_ENABLED=1
# NEXUS_SPAMBOT_CRON_HOUR=4
# NEXUS_SPAMBOT_CRON_MINUTE=10
GEMINI_API_KEY=
OPENAI_API_KEY=

# Community Factory / swarm LLM — local Ollama on LAN (e.g. Mac Mini). When set, tried before Gemini/OpenAI.
# Example: NEXUS_OLLAMA_BASE_URL=http://192.168.1.50:11434
# NEXUS_OLLAMA_BASE_URL=
# NEXUS_OLLAMA_MODEL=llama3

# Broker (default template — adjust per machine).
# Master on Windows often uses loopback / [::1] in REDIS_URL; fleet stub IP may be rewritten.
REDIS_URL=redis://127.0.0.1:6379/0

# ── Docker Redis master (docker-compose.redis-master.yml) ─────────────────────
# Required for that compose file; must match the password inside REDIS_URL on all clients.
# REDIS_PASSWORD=generate-a-long-random-secret
# On the master host (API, dispatcher, local tools): use loopback with auth, e.g.
# REDIS_URL=redis://:SAME_AS_REDIS_PASSWORD@127.0.0.1:6379/0

# ── Remote worker (laptop) — REQUIRED on worker PCs; do NOT leave 127.0.0.1 here ─
# Master Redis must listen on the LAN (Docker: ports 6379:6379, bind 0.0.0.0, requirepass set).
# Open the host firewall on the master: sudo sh ./setup_host_firewall.sh
# NODE_ROLE=worker
# REDIS_HOST=10.100.102.8
# MASTER_IP=10.100.102.8
# REDIS_URL=redis://:YOUR_PASSWORD@10.100.102.8:6379/0

# Master Windows + bundled redis-server.exe: set 1 so nexus_launcher passes redis.windows-lan.conf (bind 0.0.0.0).
# NEXUS_REDIS_LISTEN_LAN=1

# Optional: also supported as NEXUS_SECRET_OPENAI_API_KEY for the vault overlay.

# ── Retention Guardian (Telegram group member monitoring, ~every 4h) ─────────
# RETENTION_MONITOR_ENABLED=1
# RETENTION_MONITOR_INTERVAL_S=14400
# RETENTION_MONITOR_WARMUP_S=120
# RETENTION_MEMBER_BASELINE=2100
# RETENTION_DROP_ALERT_PCT=5
# RETENTION_TELETHON_SESSION=C:\path\to\session\retention_monitor
# RETENTION_GROUPS_JSON=[{"id":"-1001234567890","label":"Group A"},{"id":"-1009876543210","label":"B"}]
# RETENTION_INVITE_LINKS_JSON=[{"group_id":"-1001234567890","invite_hash":"AbCdEfGh"}]

# ── Night Watch (swarm warmer + retention + scalper live) ────────────────────
# NIGHT_WATCH_MANIFEST=config/night_watch_manifest.json
# python scripts/night_watch_execution_init.py --apply

# ── Linux workers: muscle mode (~90% CPU target, high ARQ concurrency) ───────
# NEXUS_WORKER_CPU_UTIL_TARGET=90
# NEXUS_WORKER_LOW_POWER=0

# ── Master dynamic power (night 00:00–08:00 local: ~90% cap + faster Poly5M) ─
# NEXUS_DYNAMIC_POWER=1
# NEXUS_POWER_NIGHT_CPU_PCT=90
# NEXUS_POWER_ACTIVE_CPU_PCT=50
# NEXUS_POWER_IDLE_ACTIVE_AFTER_S=300
# NEXUS_POWER_NIGHT_POLY5M_CYCLE_S=90
# NEXUS_POWER_ACTIVE_POLY5M_CYCLE_S=300

# ── Swarm Social Synthesis (AI group warmer + community identity) ───────────
# SWARM_SOCIAL_ENABLED=1
# SWARM_WARMER_CONFIG=C:\path\to\swarm_groups.json
# JSON shape: {"-1001234567890":{"group_id":-1001234567890,"timezone":"UTC","enabled":true,"group_title":"","sessions":[{"session_path":"C:\\path\\to\\session","username":"handle"}]}}

# ── Nexus Brain (self-optimizing ML layer) ───────────────────────────────────
# How many WinError 121 occurrences per 5-minute scan trigger predictive scaling.
# NEXUS_BRAIN_WIN_ERROR_THRESHOLD=5
# Initial (and minimum-floor) safety delay in seconds for Telegram sessions.
# Increased 15% on FloodWaitError; decreased 5% after 100 consecutive successes.
# NEXUS_BRAIN_SAFETY_DELAY_DEFAULT=1.0
