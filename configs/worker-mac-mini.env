# ── Nexus Worker — Mac Mini M2 Pro ───────────────────────────────────────────
# Copy this file to .env on the Mac Mini.
# Run: python3 scripts/start_worker.py

NODE_ROLE=worker
NODE_ID=worker_mac_mini
NODE_DISPLAY_NAME=Mac-Mini-M2Pro

# Point to the Master's Redis
REDIS_URL=redis://10.100.102.08:6379/0

# M2 Pro is the most powerful node — heavy compute tasks
WORKER_MAX_JOBS=16
WORKER_CAPABILITIES=any,macos,high-ram,apple-silicon,docker

# No cap — let it run at full M2 Pro power
MASTER_CPU_CAP_PERCENT=0
MASTER_RAM_CAP_MB=0

# Allow longer tasks (AI inference, heavy scraping)
TASK_DEFAULT_TIMEOUT=600
WORKER_MAX_TRIES=3

LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=8244724339:AAGPo4odPjph9yguNHr3HdVeh8-dZnM69bA
TELEGRAM_ADMIN_CHAT_ID=7849455058

GEMINI_API_KEY=AIzaSyD_kzZn2frNJ7R32iaxc7VViNkwjxmrn_0

WORKER_DEPLOY_ROOT_LINUX=/Users/yarin/Desktop/Nexus-Orchestrator

