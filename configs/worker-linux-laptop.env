# ── Nexus Worker — Linux Weak Laptop ─────────────────────────────────────────
# Copy this file to .env on the Linux laptop.
# Run: python scripts/start_worker.py

NODE_ROLE=worker
NODE_ID=worker_laptop_linux
NODE_DISPLAY_NAME=Linux-Laptop

# Point to the Master's Redis
REDIS_URL=redis://10.100.102.08:6379/0

# Weak machine — only 2 tasks at a time
WORKER_MAX_JOBS=2
WORKER_CAPABILITIES=any,linux,low-power

# Soft CPU cap — don't overheat the laptop
MASTER_CPU_CAP_PERCENT=70
MASTER_RAM_CAP_MB=1024

TASK_DEFAULT_TIMEOUT=300
WORKER_MAX_TRIES=3

LOG_LEVEL=INFO

