# ── Nexus Worker — Windows Gaming Laptop ─────────────────────────────────────
# Copy this file to .env on the Windows gaming laptop.
# Run: python scripts/start_worker.py

NODE_ROLE=worker
NODE_ID=worker_laptop_windows
NODE_DISPLAY_NAME=Gaming-Laptop-Win

# Point to the Master's Redis (master desktop IP)
REDIS_URL=redis://10.100.102.08:6379/0

# This machine is powerful — run up to 8 tasks in parallel
WORKER_MAX_JOBS=8
WORKER_CAPABILITIES=any,windows,gpu,high-ram

# No CPU cap — let it run at full power
MASTER_CPU_CAP_PERCENT=0
MASTER_RAM_CAP_MB=0

TASK_DEFAULT_TIMEOUT=300
WORKER_MAX_TRIES=3

LOG_LEVEL=INFO

