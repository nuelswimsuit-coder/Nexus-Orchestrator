# Copy to `.env` and fill in values. Do not commit `.env`.

# Optional: protect /api/sessions|swarm|deploy/* — same value as NEXT_PUBLIC_NEXUS_API_KEY in frontend .env.local
# NEXUS_API_KEY=

TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# my.telegram.org — required for POST /api/sessions/* (Telethon user sessions)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Broker: unset → Windows defaults to 127.0.0.1, Linux to 10.100.102.8 (fleet master).
# On Windows, REDIS_URL pointing at 10.100.102.8 is auto-rewritten to 127.0.0.1.
REDIS_URL=redis://127.0.0.1:6379/0

# Polymarket — master Poly trader ticks + BTC/USD cross-venue stack (Settings default: on).
POLYMARKET_BOT_ENABLED=1

# ── Polymarket live wallet (CLOB / Ultimate Scalper) ──────────────────────────
# Put secrets only in `.env` (gitignored). Simulation mode does not need these.
# Wallet private key for order signing (0x + 64 hex). Prefer this name (avoids confusing with Relayer API UUID):
#   POLYMARKET_WALLET_PRIVATE_KEY=0x...
# Legacy / aliases (same value; do NOT paste Polymarket "Relayer API Key" UUID here):
#   POLYMARKET_RELAYER_KEY=0x...
#   NEXUS_POLY_PRIVATE_KEY=0x...
#   POLY_PRIVATE_KEY=0x...
# Funder / EOA that matches the key:
# POLYMARKET_SIGNER_ADDRESS=0x...
# Optional CLOB L2 credentials (see nexus/trading/polymarket_client.py docstring):
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=
# Optional builder attribution (polymarket.com/settings → Builder):
# POLYMARKET_BUILDER_ID=Nexus
# POLY_BUILDER_API_KEY=
# POLY_BUILDER_SECRET=
# POLY_BUILDER_PASSPHRASE=

# Optional: pin Gamma market id for “Bitcoin Up or Down” price-action windows.
# POLYMARKET_BTC_PRICE_ACTION_MARKET_ID=
# Sandbox-friendly fusion threshold (0–1); maps to master strike at pct = value * 100.
# NEXUS_MIN_CONFIDENCE_SCORE=0.70

# OpenClaw: also pull Polymarket CLOB order book to Redis (disable with 0).
# OPENCLAW_FETCH_POLY_ORDERBOOK=1

# POST /api/openclaw/settings — JSON file directory + Moltbot restart (shell).
# NEXUS_OPENCLAW_CONTROL_DIR=C:\path\to\OpenClaw
# Optional: NEXUS_OPENCLAW_SETTINGS_FILENAME=openclaw_settings.json
# NEXUS_MOLTBOT_RELOAD_CMD=systemctl restart moltbot
# (fallback) NEXUS_OPENCLAW_RELOAD_CMD=...

# Optional: also supported as NEXUS_SECRET_OPENAI_API_KEY for the vault overlay.

# ── Retention Guardian (Telegram group member monitoring, ~every 4h) ─────────
# RETENTION_MONITOR_ENABLED=1
# RETENTION_MONITOR_INTERVAL_S=14400
# RETENTION_MONITOR_WARMUP_S=120
# RETENTION_MEMBER_BASELINE=2100
# RETENTION_DROP_ALERT_PCT=5
# RETENTION_TELETHON_SESSION=C:\path\to\session\retention_monitor
# RETENTION_GROUPS_JSON=[{"id":"-1001234567890","label":"Group A"},{"id":"-1009876543210","label":"B"}]
# RETENTION_INVITE_LINKS_JSON=[{"group_id":"-1001234567890","invite_hash":"AbCdEfGh"}]

# ── Night Watch (swarm warmer + retention + scalper live) ────────────────────
# NIGHT_WATCH_MANIFEST=config/night_watch_manifest.json
# python scripts/night_watch_execution_init.py --apply

# ── Linux workers: muscle mode (~90% CPU target, high ARQ concurrency) ───────
# NEXUS_WORKER_CPU_UTIL_TARGET=90
# NEXUS_WORKER_LOW_POWER=0

# ── Master dynamic power (night 00:00–08:00 local: ~90% cap + faster Poly5M) ─
# NEXUS_DYNAMIC_POWER=1
# NEXUS_POWER_NIGHT_CPU_PCT=90
# NEXUS_POWER_ACTIVE_CPU_PCT=50
# NEXUS_POWER_IDLE_ACTIVE_AFTER_S=300
# NEXUS_POWER_NIGHT_POLY5M_CYCLE_S=90
# NEXUS_POWER_ACTIVE_POLY5M_CYCLE_S=300

# ── Swarm Social Synthesis (AI group warmer + community identity) ───────────
# SWARM_SOCIAL_ENABLED=1
# SWARM_WARMER_CONFIG=C:\path\to\swarm_groups.json
# JSON shape: {"-1001234567890":{"group_id":-1001234567890,"timezone":"UTC","enabled":true,"group_title":"","sessions":[{"session_path":"C:\\path\\to\\session","username":"handle"}]}}
